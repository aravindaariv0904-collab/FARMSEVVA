# ============================================================
# Farm Seeva — Monorepo .gitignore
# ============================================================

# ── Secrets & Environment ───────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
service-account.json
firebase-adminsdk*.json

# ── Node / npm (backend + gateway + mobile) ─────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
build/
.npm

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo

# ── Python AI Engine ────────────────────────────────────────
ai-engine/venv/
ai-engine/__pycache__/
ai-engine/**/__pycache__/
ai-engine/**/*.pyc
ai-engine/**/*.pyo
ai-engine/.env
*.pyc
*.pyo
*.pyd
__pycache__/
.Python
*.egg-info/
dist/
.eggs/
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ── Prisma ───────────────────────────────────────────────────
backend/prisma/migrations/**/migration_lock.toml

# ── React Native / Expo (mobile) ────────────────────────────
mobile/.expo/
mobile/android/
mobile/ios/
mobile/.env
*.orig.*
web-build/
expo-env.d.ts

# ── OS & Editors ────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Logs ────────────────────────────────────────────────────
logs/
*.log

# ── Docker ──────────────────────────────────────────────────
.dockerignore
