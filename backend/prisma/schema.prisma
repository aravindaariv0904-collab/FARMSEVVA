// Prisma schema for Farm Seeva
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String     @id @default(uuid())
  phoneNumber String     @unique
  soilData    SoilData[]
  createdAt   DateTime   @default(now())
}

model SoilData {
  id         String   @id @default(uuid())
  ph         Float
  nitrogen   Float
  phosphorus Float
  potassium  Float
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}
