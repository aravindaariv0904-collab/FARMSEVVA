generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  phoneNumber     String?          @unique
  email           String?          @unique
  isPremium       Boolean          @default(false)
  farms           Farm[]
  soilData        SoilData[]
  terraAISessions TerraAISession[]
  diseaseReports  DiseaseReport[]
  soilProfiles    SoilProfile[]
  createdAt       DateTime         @default(now())
}

model Farm {
  id           String        @id @default(uuid())
  name         String
  location     String
  gpsLat       Float?
  gpsLng       Float?
  gpsAccuracy  Float?
  boundary     String?       // Storing GeoJSON as string/json
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  soilProfiles SoilProfile[]
  createdAt    DateTime      @default(now())
}

model SoilData {
  id         String   @id @default(uuid())
  ph         Float
  nitrogen   Float
  phosphorus Float
  potassium  Float
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}

model TerraAISession {
  id              String   @id @default(uuid())
  farmerId        String
  user            User     @relation(fields: [farmerId], references: [id])
  message         String
  response        String
  language        String
  confidenceScore Float
  createdAt       DateTime @default(now())
}

model WeatherCache {
  id        Int      @id @default(autoincrement())
  lat       Float
  lon       Float
  data      String
  fetchedAt DateTime @default(now())
}

model MarketPrice {
  id          Int      @id @default(autoincrement())
  crop        String
  state       String
  price       Float
  unit        String
  market      String
  fetchedAt   DateTime @default(now())
}

model DiseaseReport {
  id          String   @id @default(uuid())
  userId      String
  cropName    String
  disease     String
  confidence  Float
  imageUrl    String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model SoilProfile {
  id                 String   @id @default(uuid())
  userId             String
  farmId             String?
  soilType           String?
  phLevel            Float?
  nitrogenLevel      Float?
  phosphorusLevel    Float?
  potassiumLevel     Float?
  zincLevel          Float?
  organicCarbon      Float?
  clay               Float?
  sand               Float?
  silt               Float?
  cec                Float?
  confidencePct      Float?
  source             String?
  method             String   @default("gps_auto")
  validationWarnings String?
  lat                Float?
  lon                Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id])
  farm               Farm?    @relation(fields: [farmId], references: [id])
}
