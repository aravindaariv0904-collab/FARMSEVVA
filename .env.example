# Backend
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/farmseeva"

# Email (Gmail recommended)
# 1. Enable 2FA on Google Account
# 2. Search "App Passwords" and create one
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-16-character-app-password"

# Security
JWT_SECRET="your-super-secret-jwt-key"

# Third-Party APIs
CLAUDE_API_KEY="your-anthropic-claude-api-key"
OPENWEATHER_API_KEY="your-open-weather-api-key"
DATA_GOV_API_KEY="your_data_gov_in_api_key"
PLANT_ID_API_KEY="your_plant_id_key"

# Frontend Integration
V1_API_PREFIX="/api/v1"

# Configuration
DEFAULT_LAT=9.5916
DEFAULT_LON=77.6272
WEATHER_CACHE_MINUTES=60
MARKET_CACHE_MINUTES=360
