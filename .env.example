# Backend Environment Variables
NODE_ENV=development
PORT=5000
DATABASE_URL="postgresql://postgres:password@localhost:5432/farm_seeva?schema=public"
REDIS_URL="redis://localhost:6379"

# Security
CORS_ORIGIN="*"
JWT_SECRET="your-super-secret-jwt-key"

# AI Engine Variables
AI_ENGINE_URL="http://localhost:8000/api/v1"

# Third-Party APIs (Placeholders)
FIREBASE_PROJECT_ID="farm-seeva-demo"
OPENWEATHER_API_KEY="your-openweather-api-key"
CLAUDE_API_KEY="your-anthropic-claude-api-key"
SOILGRIDS_API_KEY="your-soilgrids-api-key"
