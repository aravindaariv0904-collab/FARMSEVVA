{
  "name": "farm-seeva-monorepo",
  "version": "1.0.0",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"node gateway.js\"",
    "start:backend": "cd backend && npm run dev",
    "docker:up": "docker-compose up -d",
    "prisma:init": "cd backend && npx prisma generate && npx prisma migrate dev --name init"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6"
  }
}
